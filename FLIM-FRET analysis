# -------------------------------
# Complete pipeline: log shift + ANOVA + Tukey + violin plot
# -------------------------------

# 1️⃣ Install and load packages
packages <- c("ggplot2", "dunn.test", "multcompView", "dplyr")
for (pkg in packages) {
  if (!require(pkg, character.only = TRUE)) {
    install.packages(pkg, dependencies = TRUE)
    library(pkg, character.only = TRUE)
  }
}

# 2️⃣ Prepare data
df <- as.data.frame(df)
df$Treatment <- as.factor(df$Treatment)
df$Exp <- as.factor(df$Exp)

# Shift data to make all values positive for log transform
min_val <- min(df$FLIM_FRET_efficiency_pc, na.rm = TRUE)
df$FLIM_shift <- df$FLIM_FRET_efficiency_pc + abs(min_val) + 1
df$FLIM_log <- log(df$FLIM_shift)

# 3️⃣ ANOVA on log-transformed data
anova_log <- aov(FLIM_log ~ Treatment, data = df)
summary(anova_log)

# 4️⃣ Tukey post-hoc test
tukey <- TukeyHSD(anova_log)

# 5️⃣ Generate significance letters from Tukey results
tukey_letters <- multcompLetters(tukey$Treatment[, "p adj"])$Letters

# Map letters to treatments
treatments <- levels(df$Treatment)
letters_df <- data.frame(
  Treatment = treatments,
  Letters = tukey_letters[treatments]
)

# 6️⃣ Compute max y per Treatment for plotting letters
y_max <- df %>%
  group_by(Treatment) %>%
  summarize(y = max(FLIM_FRET_efficiency_pc, na.rm = TRUE)) %>%
  left_join(letters_df, by = "Treatment")

# 7️⃣ Map long treatment names to short codes for clarity (optional)
short_names <- paste0("T", seq_along(treatments))
name_map <- setNames(short_names, treatments)
df$Treatment_code <- name_map[df$Treatment]

# 8️⃣ Plot violin with jittered points (semi-transparent) and Tukey letters
ggplot(df, aes(x = Treatment, y = FLIM_FRET_efficiency_pc, fill = Treatment)) +
  geom_violin(trim = FALSE, alpha = 0.6) +
  geom_boxplot(width = 0.1, outlier.shape = NA) +
  geom_jitter(aes(shape = Exp), width = 0.15, size = 2, alpha = 0.5, color = "black") +
  geom_text(data = y_max,
            aes(x = Treatment, y = y + max(df$FLIM_FRET_efficiency_pc) * 0.05, label = Letters),
            inherit.aes = FALSE,
            size = 5) +
  scale_shape_manual(values = c("1" = 16, "2" = 17), name = "Experiment") +
  theme_minimal() +
  labs(
    title = "Violin plot of FLIM-FRET efficiency by Treatment",
    y = "FLIM-FRET efficiency (%)",
    x = "Treatment"
  ) +
  theme(
    legend.position = "right",
    axis.text.x = element_text(angle = 45, hjust = 1)
  )
